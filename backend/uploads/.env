# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI="mongodb://localhost:27017/rti-connect"

# JWT - Use a strong secret in production
JWT_SECRET="your_super_secret_jwt_key_change_this_in_production_make_it_longer_and_complex"
JWT_EXPIRE=7d

# Email Configuration (Gmail)
EMAIL_USER="test@gmail.com
EMAIL_PASS="testpassword"
# For Gmail, use App Password instead of your regular password
# Generate at: https://myaccount.google.com/apppasswords  # Replace with actual app password

# Frontend URL
FRONTEND_URL="http://localhost:3000"

# Razorpay (for fee payment)
RAZORPAY_KEY_ID="your_razorpay_key_id_here"
RAZORPAY_KEY_SECRET="your_razorpay_key_secret_here"

# Twilio (for SMS - optional)
TWILIO_SID="your_twilio_sid_here"
TWILIO_AUTH_TOKEN="your_twilio_auth_token_here"
TWILIO_PHONE="your_twilio_phone_number_here"

# Upload Directory
UPLOAD_PATH="uploads"
MAX_FILE_SIZE=5242880  # 5MB in bytes
# Alternative: MAX_FILE_SIZE="5mb"  # If your parser supports string format